#compdef txtfind

autoload -U is-at-least

_txtfind() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-i[大文字・小文字を区別せずに検索する]' \
'--ignore-case[大文字・小文字を区別せずに検索する]' \
'-n[行番号を表示する（現在はデフォルトで表示）]' \
'--line-number[行番号を表示する（現在はデフォルトで表示）]' \
'-c[一致件数のみを表示する]' \
'--count[一致件数のみを表示する]' \
'--completions[各シェル用の補完ファイルを生成する]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_txtfind_commands] )) ||
_txtfind_commands() {
    local commands; commands=()
    _describe -t commands 'txtfind commands' commands "$@"
}

if [ "$funcstack[1]" = "_txtfind" ]; then
    _txtfind "$@"
else
    compdef _txtfind txtfind
fi
