
use builtin;
use str;

set edit:completion:arg-completer[txtfind] = {|@words|
    fn spaces {|n|
        builtin:repeat $n ' ' | str:join ''
    }
    fn cand {|text desc|
        edit:complex-candidate $text &display=$text' '(spaces (- 14 (wcswidth $text)))$desc
    }
    var command = 'txtfind'
    for word $words[1..-1] {
        if (str:has-prefix $word '-') {
            break
        }
        set command = $command';'$word
    }
    var completions = [
        &'txtfind'= {
            cand -i '大文字・小文字を区別せずに検索する'
            cand --ignore-case '大文字・小文字を区別せずに検索する'
            cand -n '行番号を表示する（現在はデフォルトで表示）'
            cand --line-number '行番号を表示する（現在はデフォルトで表示）'
            cand -c '一致件数のみを表示する'
            cand --count '一致件数のみを表示する'
            cand --completions '各シェル用の補完ファイルを生成する'
            cand -h 'Print help'
            cand --help 'Print help'
            cand -V 'Print version'
            cand --version 'Print version'
        }
    ]
    $completions[$command]
}
